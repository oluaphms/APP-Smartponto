# ========== APIs serverless (Vercel / produção) ==========
# Service Role (Dashboard → Settings → API): necessária para rotas /api/rep/* com API_KEY e para validar JWT no servidor.
# Em desenvolvimento, se não definir, o proxy REP usa só VITE_SUPABASE_ANON_KEY + JWT do usuário logado (RLS).
# SUPABASE_SERVICE_ROLE_KEY=

# Chave para APIs: POST /api/rep/punch, /api/rep/sync, /api/punches, etc.
# Gere uma chave forte (ex: openssl rand -hex 32) e use a mesma no header: Authorization: Bearer <API_KEY>
API_KEY=

# Opcional: chave só para relógios REP (POST /api/rep/punch). Se não definir, usa API_KEY.
# REP_API_KEY=

# Opcional: segredo para cron (sincronização REP a cada 5 min). No Vercel, defina CRON_SECRET e o cron envia esse valor no Authorization.
CRON_SECRET=
# Em produção (Vercel): Settings → Environment Variables → CRON_SECRET = mesmo valor que você usar no cron

# Proxy /api/rep/status e /api/rep/punches: mesmo token do agente local ou integração (alternativa ao JWT do usuário).
# Se não definir, usa API_KEY.
# REP_BRIDGE_TOKEN=
# REP_AGENT_TOKEN=

# Agente local (scripts/rep-agent.mjs): URL do SaaS e relógio na LAN
# REP_SAAS_URL=https://seu-app.vercel.app
# REP_DEVICE_IP=192.168.0.38
# REP_DEVICE_PORT=80
# REP_COMPANY_ID=<uuid da empresa>
# REP_DEVICE_ID=<uuid opcional do rep_devices>

# Opcional: aceitar TLS inseguro em todos os relógios REP (certificado autoassinado). Preferir flags no cadastro do dispositivo.
# REP_DEVICE_TLS_INSECURE=1
